{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "make",
            "type": "shell",
            "command": "cd ${workspaceFolder}/Builds/LinuxMakefile && make -j 2",
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "label": "makeRelease",
            "type": "shell",
            "command": "cd ${workspaceFolder}/Builds/LinuxMakefile && make CONFIG=Release -j 2",
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "label": "make clean",
            "type": "shell",
            "command": "cd ${workspaceFolder}/Builds/LinuxMakefile && make clean",
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Build Release (x64) - EmergeNS",
            "type": "shell",
            "command": "cmd.exe",
            "args": [
                "/d",
                "/c",
                "for /f \"usebackq tokens=*\" %i in (`\"%ProgramFiles(x86)%\\Microsoft Visual Studio\\Installer\\vswhere.exe\" -latest -property installationPath`) do (call \"%i\\VC\\Auxiliary\\Build\\vcvars64.bat\" && \"%i\\MSBuild\\Current\\Bin\\MSBuild.exe\" \"${workspaceFolder}\\Builds\\VisualStudio2022\\EmergeNS.sln\" /t:Build /m /p:Configuration=Release /p:Platform=x64 /p:WindowsTargetPlatformVersion=10.0.26100.0)"
            ],
            "options": {
                "cwd": "${workspaceFolder}",
                "shell": {
                    "executable": "cmd.exe"
                }
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Clean Release (x64) - EmergeNS",
            "type": "shell",
            "command": "cmd.exe",
            "args": [
                "/d",
                "/c",
                "for /f \"usebackq tokens=*\" %i in (`\"%ProgramFiles(x86)%\\Microsoft Visual Studio\\Installer\\vswhere.exe\" -latest -property installationPath`) do (call \"%i\\VC\\Auxiliary\\Build\\vcvars64.bat\" && \"%i\\MSBuild\\Current\\Bin\\MSBuild.exe\" \"${workspaceFolder}\\Builds\\VisualStudio2022\\EmergeNS.sln\" /t:Clean /m:1 /p:Configuration=Release /p:Platform=x64 /p:WindowsTargetPlatformVersion=10.0.26100.0)"
            ],
            "options": {
                "cwd": "${workspaceFolder}",
                "shell": {
                    "executable": "cmd.exe"
                }
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Run EmergeNS (Release x64)",
            "type": "shell",
            "command": "${workspaceFolder}\\Builds\\VisualStudio2022\\x64\\Release\\App\\EmergeNS.exe",
            "options": {
                "cwd": "${workspaceFolder}"
            }
        },
        {
            "type": "cppbuild",
            "label": "C/C++: g++.exe build active file",
            "command": "C:\\msys64\\ucrt64\\bin\\g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        }
    ]
}